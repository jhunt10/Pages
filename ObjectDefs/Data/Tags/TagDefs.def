{"Armor":{"Abreviation":"ARM","AppliesTo":["Stat"],"Description":"@@#Stat:Armor@@ | @@#Color:Blue:Armor@@ provides protection against @@#Color:Blue:Physical Damage@@. Each point of @@#Color:Blue:Armor@@ is equal to a 1% reduction in damage.","DisplayName":"Armor"},"Fast":{"Abreviation":"Fast","AppliesTo":["Action"],"Description":"@@#Color:Blue:Fast@@ @@#Color:Red:Actions@@ are preformed early in the @@#Color:Red:Turn@@, usually before other @@#Color:Red:Actors@@ move, regardless of @@#Stat:Speed@@.","DisplayName":"Fast"},"HeavyWeapon":{"Abreviation":"HeavyWpn","AppliesTo":["Weapon"],"Description":"@@#Color:Blue:Heavy Weapons@@ are large two-handed @@#Color:Blue:Weapons@@ that generally require both @@#Color:Blue:MainHand@@ and @@#Color:Blue:OffHand@@ to be used.","DisplayName":"Heavy Weapon"},"LightWeapon":{"Abreviation":"LightWpn","AppliesTo":["Weapon"],"Description":"@@#Color:Blue:Light Weapons@@ are smaller single handed @@#Color:Blue:Weapons@@ that generally can be used in @@#Color:Blue:OffHand@@ when @@#Color:Blue:MainHand Weapon@@ is also a @@#Color:Blue:Light Weapon@@.","DisplayName":"Light Weapon"},"Living":{"Abreviation":"Phy","AppliesTo":["Action"],"Description":"@@#Color:Blue:Living@@ creatures are those that require food, oxygen, and love to survive. Most @@#Color:Blue:Living@@ @@#Color:Red:Actors@@ have high resistance to @@#Color:DmgColor:Light Damage@@ and can be @@#Color:Green:healed@@ by it.","DisplayName":"Physical"},"Magical":{"Abreviation":"Mag","AppliesTo":["Action"],"Description":"@@#Color:Blue:Magical@@ is a @@#Color:Blue:Tag@@ bestowed upon a select number of @@#Color:Blue:Items@@ and  @@#Color:Blue:Pages@@ which are able harness Elemental Energies in the following forms:\n\n@@#Color:DmgColor:Cold@@ low variance with higher precision and capable of inflicting @@#EftDef:AilmentChilled@@ which can lead to @@#EftDef:AilmentFrozen@@.\n\n@@#Color:DmgColor:Fire@@ standard variance and easily applied over large areas, often inclicting @@#EftDef:AilmentBurned@@.\n\n@@#Color:DmgColor:Shock@@ high variance and diffult to control, occationally inflicting @@#EftDef:AilmentShocked@@.\n\n@@#Color:DmgColor:Poison@@ standard variance but less powerful, frequently inflicting various types of @@#Color:Blue:Poisons@@.","DisplayName":"Magical"},"MedumWeapon":{"Abreviation":"MediumWpn","AppliesTo":["Weapon"],"Description":"@@#Color:Blue:Medium Weapons@@ are standard single handed @@#Color:Blue:Weapons@@ that generally can only be used in @@#Color:Blue:MainHand@@.","DisplayName":"Medium Weapon"},"Melee":{"Abreviation":"Melee","AppliesTo":["Weapon","Action"],"Description":"@@#Color:Blue:Melee@@ implies a @@#Color:Blue:Weapon@@ or @@#Color:Blue:Page@@ has a short range @@#Color:Red:Target Area@@. This generally only includes @@#Color:Blue:Actors@@ that are Adjacent and in Front of the user.","DisplayName":"Melee"},"Missile":{"Abreviation":"Missile","AppliesTo":["Weapon","Action"],"Description":"@@#Color:Blue:Missles@@ are projectiles that take time to reach target. So \"lead the shot\"","DisplayName":"Missile"},"Physical":{"Abreviation":"Phy","AppliesTo":["Action"],"Description":"@@#Color:Blue:Phy@@ means @@#Color:Blue:Physical@@. @@#Color:DmgColor:Slash@@'em, @@#Color:DmgColor:Pierce@@'em, hit'em with something @@#Color:DmgColor:Blunt@@, or just @@#Color:DmgColor:Crash@@ into them. You might even make'm @@#Color:DmgColor:Slash:Bleed@@, @@#Color:DmgColor:Pierce:Blinded@@, or @@#Color:DmgColor:Blunt:Dazed@@ if your good. But you usssaly gotta do something different to get'em @@#Color:DmgColor:Crash:Geased@@.","DisplayName":"Physical"},"Ranged":{"Abreviation":"Ranged","AppliesTo":["Weapon","Action"],"Description":"@@#Color:Blue:Ranged@@ implies a @@#Color:Red:Weapon@@ or @@#Color:Blue:Page@@ has a medium to long range @@#Color:Red:Target Area@@. @@#Color:Blue:Ranged Attacks@@ are generally weaker than @@#Color:Blue:Melee@@, but can reach distant @@#Color:Red:Actors@@.","DisplayName":"Ranged"},"Slow":{"Abreviation":"Slow","AppliesTo":["Action"],"Description":"@@#Color:Blue:Slow@@ @@#Color:Red:Actions@@ are preformed late in the @@#Color:Red:Turn@@, usually after other @@#Color:Red:Actors@@ move, regardless of @@#Stat:Speed@@.","DisplayName":"Slow"},"Spell":{"Abreviation":"Spell","AppliesTo":["Action"],"Description":"The @@#Color:Blue:Spell Tag@@ denotes particular @@#Color:Red:Action Pages@@ as catagorized by the use of @@#Color:Blue:Magical@@ Elemental energies generated by and manipulated through the @@#Color:Blue:Page@@ System.","DisplayName":"Spell"},"Tactic":{"Abreviation":"Tactic","AppliesTo":["Action"],"Description":"@@#Color:Blue:Tactic@@ means @@#Color:Blue:Physical@@ @@#Color:Red:Action@@","DisplayName":"Tactic"},"Unarmed":{"Abreviation":"Tactic","AppliesTo":["Action"],"Description":"@@#Color:Blue:Unarmed@@ @@#Color:Red:Actors@@ have no @@#Color:Red:Weapon@@ equip and default to thier @@#Color:Red:Unarmed Damage@@ when making @@#Color:Red:Weapon Attacks@@.","DisplayName":"Tactic"},"Undead":{"Abreviation":"Phy","AppliesTo":["Action"],"Description":"@@#Color:Blue:Undead@@ are \"dead\" @@#Color:Red:Actors@@, reactived by the @@#Color:Blue:PAGE@@ System. They sustain thier forms with @@#Color:DmgColor:Dark@@ energy and are @@#Color:Green:healed@@ by further exposure. Inversely, @@#Color:DmgColor:Light@@ has proven highly disruptive to this process.","DisplayName":"Physical"}}