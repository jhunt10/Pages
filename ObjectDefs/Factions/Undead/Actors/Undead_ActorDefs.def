	"Skeleton": {
		"!ObjectScript": "res://assets/Scripts/Actors/BaseActor.gd",
		"!ParentKey": "#BaseUndead",
		"#ObjDetails": {
			"Description": "A spooky scary @@#Color:Red:Skeleton@@ risen from the dead. This form of reanimation accounts for a lack of muscle tissue by focusing on direct manipulation of bone. This results in an @@#Tag:Undead@@ that is physically weaker, but has the @@#Color:Red:Agility@@ required to use @@#Tag:Ranged:Hint:Ranged Weapons@@.\n\nThier exposed bone is resistant to @@#Color:DmgColor:Slash@@ and @@#Color:DmgColor:Pierce@@, but is quite vulnerable to @@#Color:DmgColor:Blunt@@ and @@#Color:DmgColor:Crash@@. They often remain on back lines using range to attack from afar. But, while some may view them as nightmarish monsters, I like to believe there's a @@#Color:Red:Skeleton@@ inside us all.",
			"DisplayName": "Skeleton",
			"LargeIcon": "Sprites/Skeleton_Icon.png",
			"ObjectType": "Actor",
