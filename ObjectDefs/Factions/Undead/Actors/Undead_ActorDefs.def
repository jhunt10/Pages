	"ZombieBasic": {
		"!ObjectScript": "res://assets/Scripts/Actors/BaseActor.gd",
		"!ParentKey": "#BaseUndead",
		"#ObjDetails": {
			"Description": "A common form of @@#Tag:Undead@@ created through the reanimation of a @@#Color:Red:Corpse@@. @@#Color:Red:Zombies@@ are peaceful and docile beings almost never resorting to violence, except towards all living creatures whom they will relentlessly attack on sight. They have an innate love of helicopters, gleefully chasing after any they see fly by. But sadly, no one ever let's them ride in one.",
