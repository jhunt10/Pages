{
	"BanditArcher_TitlePage": {
		"!ObjectScript": "res://assets/Scripts/Items/Pages/PageItemTitle.gd",
		"!ParentKey": "BanditBase_TitlePage",
		"#ObjDetails": {
			"Description": "@@#Color:Red:Bandit Archers@@ are a subspecies of @@#Color:Red:Bandit@@ who specialize in @@#Tag:Physical@@ @@#Tag:Ranged:Hint:Ranged Attacks@@ with a @@#Color:Red:Bow@@.\n\nThrough years of grueling training in short shorts, these brave few have learned the secrets of the bare leg; sacrificing @@#Stat:Strength@@ and @@#Stat:Armor@@ in favor of higher @@#Stat:Agility@@ and @@#Stat:Speed@@.\n\nNaturally this makes them best suited for attacking from a distance, but despite all their training @@#Color:Red:they still can't hit a moving target@@.",
			"DisplayName": "Bandit Archer",
			"LargeIcon": "Sprites/BanditArcherTitle_Icon.png",
