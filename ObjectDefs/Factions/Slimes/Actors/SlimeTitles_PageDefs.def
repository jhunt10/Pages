	"SlimePoison_TitlePage": {
		"!ObjectScript": "res://assets/Scripts/Items/Pages/PageItemTitle.gd",
		"!ParentKey": "#BaseTitlePage",
		"#ObjDetails": {
			"Description": "With a high tolerance to toxins and poor personal hygiene, @@#Color:Red:Slimes@@ often become polluted with whatever is in their environment. After a @@#Color:Red:Slime@@ ingests enough material with @@#Tag:Magical@@ properties, the @@#Color:Blue:PAGE@@ System appears to misinterpret the @@#Color:Red:Slime@@ as possessing the same properties of the given material. At this point, the @@#Color:Red:Slime@@ will alter it's color to conform to cultural norms.\n\n@@#Color:Red:Green Slimes@@ have absorbed large amounts of poisonous plants, toxic waste, and internet comment sections. Any contact with these them is recognized as @@#Color:DmgColor:Poison:Poison Damage@@ and can be potent enough to inflict deadly @@#EftDef:AilmentPoisoned:Link@@ status to the idiot who touched a Poison Slime with their bare hands.",
			"DisplayName": "Poison Slime",
			"LargeIcon": "Sprites/GreenSlime_Icon.png",
			"ObjectType": "Item",
