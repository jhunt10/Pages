{"Bandit_PageBook":{"!ObjectScript":"res://assets/Scripts/Items/Equipment/BaseQueEquipment.gd","!ParentKey":"BasePageBook_Mundane","#ObjDetails":{"Description":"Written and self published by Benjamin \"Skull Crusher\" Taylors, it was quickly accepted as the standard guide for practical violence among the banditry community.","DisplayName":"Bandit Bible","LargeIcon":"Sprites/BanditBook.png","ObjectType":"Item","SmallIcon":"Sprites/BanditBook.png","SnippetDesc":"The de facto guide to all things banditry.","Tags":["PageBook"],"Taxonomy":["Item","Equipment","PageBook"]},"BookData":{"BaseActionCount":6.0,"BasePassiveCount":2.0,"PagesPerRound":4.0},"EquipmentData":{"ItemSlotsData":[{"Count":2.0,"DisplayName":"Attacks","FilterData":{"RequiredTags":"Attack"},"Key":"Attacks"}]},"_DefVersion":"1"},"BasePageBook_Common":{"!ObjectScript":"res://assets/Scripts/Items/Equipment/BaseQueEquipment.gd","#ObjDetails":{"Description":"Base Def for Common Page Books.","DisplayName":"Base Common Page Book","LargeIcon":"Sprites/_BaseBook_Common.png","ObjectType":"Item","SmallIcon":"Sprites/_BaseBook_Common.png","SnippetDesc":"Base Def for Common Page Books.","Tags":["PageBook"],"Taxonomy":["Item","Equipment","PageBook"]},"BookData":{"BaseActionCount":8.0,"BasePassiveCount":2.0,"PagesPerRound":5.0},"EquipmentData":{"ItemSlotsData":[]},"ItemData":{"Rarity":"Common","Value":50.0},"_DefVersion":"1"},"BasePageBook_Mundane":{"!ObjectScript":"res://assets/Scripts/Items/Equipment/BaseQueEquipment.gd","#ObjDetails":{"Description":"Base Def for Mundane Page Books.","DisplayName":"Base Mundane Page Book","LargeIcon":"Sprites/_BaseBook_Mundane.png","ObjectType":"Item","SmallIcon":"Sprites/_BaseBook_Mundane.png","SnippetDesc":"Base Def for Mundane Page Books.","Tags":["PageBook"],"Taxonomy":["Item","Equipment","PageBook"]},"BookData":{"BaseActionCount":7.0,"BasePassiveCount":1.0,"PagesPerRound":4.0},"EquipmentData":{"ItemSlotsData":[]},"ItemData":{"Rarity":"Mundane","Value":50.0},"_DefVersion":"1"},"Doc